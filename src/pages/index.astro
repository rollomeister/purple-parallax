		position: relative;
		z-index: 1;
	}

	.hero-facts {
		position: relative;
		z-index: 1;
		display: grid;
		gap: 0.8rem;
		padding: 1.4rem 0 0;
		margin: 1.4rem 0 0;
		list-style: none;
		border-top: 1px solid rgba(0, 0, 0, 0.08);
	}

	.hero-facts li {
