---

<Layout
	title="Triim Kurbas | Costume Artist"
	description="Editorial-style portfolio for costume artist Triim Kurbas, featuring film, television, and commercial work."
>
	<main class="page">
		<header class="hero" id="home">
			<nav class="nav">
				<a class="brand" href="#home">
					<span>Triim Kurbas</span>
				</a>
				<div class="links">
					<a href="#home">Home</a>
					<a href="#work">Costume work</a>
					<a href="#contact">Contact</a>
				</div>
			</nav>

			<div class="hero-grid">
				<div class="hero-copy">
					<p class="intro">
						TRIIM KURBAS also known as Triim Peetsalu before 2025 - is a COSTUME DESIGNER working on a TV-series, Film, commercials and photoshoots.
					</p>
					<p class="intro">
						My background is Estonian Art Academy Jewellry and Production Design. Before costume I was working in jewellery.
					</p>
					<p class="intro">
						Here is a list of my work done for TV and Film
					</p>
					<div class="actions">
						<a class="button primary" href="#work">Browse Selected Work</a>
					</div>
				</div>
				<aside class="hero-aside">
					<div class="portrait-card">
						<img
							class="hero-portrait"
							src={heroPortrait.src}
							width={heroPortrait.width}
							height={heroPortrait.height}
							alt="Portrait of Triim Kurbas"
							loading="eager"
						/>
					</div>
				</aside>
			</div>
		</header>

		<section class="section story-section">
			<div class="section-heading">
				<p class="section-label">Practice</p>
				<h2>An editorial portfolio shaped from the original project plan.</h2>
			</div>
			<div class="story-grid">
				<article class="story-card large">
					<p class="story-kicker">Approach</p>
					<h3>Craft-led costume design with a material eye.</h3>
					<p>
						The work spans family television, period film, music video, drama, and
						international co-productions. Each project is approached through texture,
						proportion, world-building, and the emotional logic of what a character wears.
					</p>
				</article>
				<article class="story-card">
					<p class="story-kicker">Commercials</p>
					<p>
						Commercial costume work includes projects for Coca-Cola, Sony, Samsung,
						Expert, DNA, Elisa Eesti, and Eesti Pagar.
					</p>
				</article>
				<article class="story-card">
					<p class="story-kicker">Background</p>
					<p>
						A foundation in jewellery and production design informs a detail-oriented
						approach to fittings, styling, sourcing, and costume continuity.
					</p>
				</article>
			</div>
		</section>

		<section class="section feature-section">
			<div class="feature-frame">
				<div class="feature-copy">
					<p class="section-label">Selected Focus</p>
					<h2>Papsid</h2>
					<p class="feature-meta">Estonian family TV series, 2022-present</p>
					<p>
						Head costume designer across a long-running television project, shaping
						recurring visual identity over multiple seasons.
					</p>
					<a class="text-link" href="https://www.youtube.com/watch?v=MywN9DJHdA8" target="_blank" rel="noreferrer">
						View trailer
					</a>
				</div>
				<img
					class="feature-image"
					src={getYouTubeThumbnail("https://www.youtube.com/watch?v=MywN9DJHdA8")}
					alt="Papsid trailer still"
					loading="eager"
				/>
			</div>
		</section>

		<section class="section" id="work">
			<div class="section-heading section-heading-wide">
				<div>
					<p class="section-label">Costume Work</p>
					<h2>Selected projects across television, film, and music video.</h2>
				</div>
				<p class="section-intro">
					A working portfolio of productions, collaborators, and costume roles drawn
					from the original document and translated into a more visual archive.
				</p>
			</div>

			<div class="project-grid">
				{
					featuredProjects.map((project, index) => (
						<article class:list={["project-card", index % 5 === 0 && "project-card-tall"]}>
							<div class="project-media">
								{
									project.image ? (
										<img
											class="project-image"
											src={project.image}
											alt={`${project.title} reference still`}
											loading="lazy"
										/>
									) : (
										<div class="project-image fallback" aria-hidden="true">
											<span>{project.title}</span>
										</div>
									)
								}
								<div class="project-overlay">
									<p class="project-kicker">{project.subtitle}</p>
									<h3>{project.title}</h3>
								</div>
							</div>

							<div class="project-body">
								<p class="project-meta">{project.meta}</p>
								<dl class="project-details">
									<div>
										<dt>Production</dt>
										<dd>{project.production}</dd>
									</div>
									<div>
										<dt>Position</dt>
										<dd>{project.role}</dd>
									</div>
								</dl>
								{
									project.link !== "#" && (
										<a class="project-link" href={project.link} target="_blank" rel="noreferrer">
											Open reference
										</a>
									)
								}
							</div>
						</article>
					))
				}
			</div>
		</section>

		<section class="section spotlight">
			<div class="spotlight-shell">
				<div class="section-heading">
					<p class="section-label">Commercial Work</p>
					<h2>Brand-facing styling and costume for Estonian and international productions.</h2>
				</div>
				<div class="spotlight-grid">
					<div class="spotlight-card">
						<p>
							The original plan lists 13 commercial projects between 2017 and 2020,
							with work connected to Coca-Cola, Sony, Samsung, Expert, DNA, Elisa Eesti,
							and Eesti Pagar.
						</p>
					</div>
					<div class="spotlight-card muted">
						<p>
							Production partners noted in the source file include Nafta Films, Get
							Shot Films, and Allfilm. This section can grow into a campaign archive,
							client strip, or a dedicated commercial portfolio page later.
						</p>
					</div>
				</div>
			</div>
		</section>

		<section class="section contact-section" id="contact">
			<div class="contact-shell">
				<div class="contact-copy">
					<p class="section-label">Contact</p>
					<h2>Available for productions, collaborations, and creative commissions.</h2>
					<p>
						Costume designer based in Tallinn, Estonia. For film, television,
						commercial, and editorial enquiries, reach out directly.
					</p>
				</div>

				<div class="contact-card">
					<a href="mailto:triim.kurbas@gmail.com">triim.kurbas@gmail.com</a>
					<a href="tel:+37253439902">+372 5343 9902</a>
					<p>Tallinn, Estonia</p>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
