		border-radius: 999px;
		background: rgba(255, 255, 255, 0.66);
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--muted-strong);
	}

	.section {
		padding: 5rem 0;
	}

	.section-heading {
		max-width: 42rem;
		margin-bottom: 2.4rem;
	}

	.section-heading-wide {
		max-width: none;
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(16rem, 24rem);
		gap: 2rem;
		align-items: end;
	}

	.section-intro {
		margin-bottom: 0.35rem;
	}

	.story-grid {
		display: grid;
		grid-template-columns: 1.15fr 1fr 1fr;
		gap: 1rem;
	}

	.story-card,
	.spotlight-card,
	.contact-card {
		padding: 1.6rem;
		border: 1px solid rgba(0, 0, 0, 0.12);
		border-radius: 1.8rem;
		background: rgba(255, 255, 255, 0.8);
		box-shadow: 0 18px 42px rgba(0, 0, 0, 0.05);
	}

	.story-card.large {
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(236, 236, 236, 0.8)),
			rgba(255, 255, 255, 0.8);
	}

	.feature-frame {
		display: grid;
		grid-template-columns: minmax(0, 0.85fr) minmax(20rem, 1.2fr);
		gap: 1.2rem;
		padding: 1.2rem;
		border: 1px solid rgba(0, 0, 0, 0.12);
		border-radius: 2rem;
		background: rgba(255, 255, 255, 0.74);
		box-shadow: 0 24px 64px rgba(0, 0, 0, 0.06);
	}

	.feature-copy {
		padding: 1.5rem;
		display: grid;
		align-content: center;
	}

	.feature-meta,
	.project-meta {
		color: var(--muted-strong);
	}

	.feature-image {
		width: 100%;
		min-height: 26rem;
		height: 100%;
		object-fit: cover;
		display: block;
		border-radius: 1.5rem;
	}

	.text-link,
	.project-link {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		color: var(--accent-strong);
		font-size: 0.9rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

