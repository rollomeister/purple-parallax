import heroPortrait from "../assets/images/triin.p_2bw.jpg";

const getYouTubeThumbnail = (url: string) => {
	try {
		const parsed = new URL(url);
		const shortId = parsed.hostname.includes("youtu.be") ? parsed.pathname.slice(1) : null;
		const watchId = parsed.searchParams.get("v");
		const id = shortId || watchId;
		return id ? `https://img.youtube.com/vi/${id}/hqdefault.jpg` : null;
	} catch {
		return null;
	}
};

const getVimeoThumbnail = (url: string) => {
	try {
		const parsed = new URL(url);
		const match = parsed.pathname.match(/\/(\d+)/);
		return match ? `https://vumbnail.com/${match[1]}.jpg` : null;
	} catch {
		return null;
	}
};

